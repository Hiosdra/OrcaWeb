{
  "name": "orca-web",
  "private": true,
  "version": "0.7.62",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "build": "tsc -b && vite build",
    "build:cf": "tsc -b && node scripts/cf-build.mjs",
    "preview": "vite preview",
    "setup": "node scripts/download-wasm.mjs",
    "smoke-test": "node orca-wasm/scripts/smoke-test.mjs",
    "test:e2e": "playwright test",
    "test": "vitest run src",
    "test:wasm-malloc": "vitest run src/lib/wasm-loader.test.ts",
    "generate-corpus": "node scripts/generate-corpus.mjs",
    "benchmark-gcode": "node scripts/benchmark-gcode-compression.mjs",
    "generate-pwa-assets": "pwa-assets-generator --config pwa-assets.config.ts"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "fflate": "^0.8.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.0.18"
  }
}
